{
  "name": "the-right-tool",
  "tagline": "Why use the wrong tool when you can use the right one?",
  "description": "a curated collection of powerful yet user-friendly tools, why settle for anything less than perfect results?",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wvanderp/the-right-tool"
  },
  "scripts": {
    "start": "npm run dev",
    "app": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 & tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "postinstall": "patch-package && node -e \"const fs=require('fs'),p='node_modules/@6over3/zeroperl-ts/dist';fs.existsSync(p+'/cjs/zeroperl.wasm')&&!fs.existsSync(p+'/esm/zeroperl.wasm')&&fs.copyFileSync(p+'/cjs/zeroperl.wasm',p+'/esm/zeroperl.wasm')\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@uswriting/exiftool": "^1.0.9",
    "handlebars": "^4.7.8",
    "ical.js": "^2.2.1",
    "jsonpath": "^1.2.1",
    "localforage": "^1.10.0",
    "match-sorter": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.1",
    "sort-by": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.22.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jsonpath": "^0.2.4",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}