{
  "name": "the-right-tool",
  "tagline": "Why use the wrong tool when you can use the right one?",
  "description": "a curated collection of powerful yet user-friendly tools, why settle for anything less than perfect results?",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wvanderp/the-right-tool"
  },
  "scripts": {
    "start": "pnpm run dev",
    "app": "pnpm run dev",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 & tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "postinstall": "patch-package && node -e \"const fs=require('fs'),p='node_modules/@6over3/zeroperl-ts/dist';fs.existsSync(p+'/cjs/zeroperl.wasm')&&!fs.existsSync(p+'/esm/zeroperl.wasm')&&fs.copyFileSync(p+'/cjs/zeroperl.wasm',p+'/esm/zeroperl.wasm')\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@uswriting/exiftool": "^1.0.9",
    "handlebars": "^4.7.9",
    "ical.js": "^2.2.1",
    "jsonpath": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/jsonpath": "^0.2.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "brace-expansion": "5.0.3"
  },
  "packageManager": "pnpm@11.7.0"
}